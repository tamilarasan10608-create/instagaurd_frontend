# InstaGuard Root Environment Example
# Copy this file to backend/.env or edit backend/.env directly

DATABASE_URL=sqlite:///./instaguard.db
SECRET_KEY=instaguard-secret-key-change-in-production-32bytes
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Optional Apify Scraper Token
APIFY_API_TOKEN=
INSTAGRAM_SESSION_ID=
