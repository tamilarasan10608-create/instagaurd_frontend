# ==========================================
# InstaGuard Backend Environment Configuration
# ==========================================

# Database Configuration
# Default (Local): SQLite database (no setup required)
DATABASE_URL=sqlite:///./instaguard.db
# Alternative (Docker/Production PostgreSQL):
# DATABASE_URL=postgresql://instaguard:instaguard_secret@db:5432/instaguard

# Redis & Celery (Optional for Local thread execution; required for production Celery workers)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security & Authentication
SECRET_KEY=instaguard-secret-key-change-in-production-32bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Apify & Instagram Scraper Credentials
# (If APIFY_API_TOKEN is blank, InstaGuard uses direct forensic image analysis)
APIFY_API_TOKEN=
INSTAGRAM_SESSION_ID=
MAX_POSTS=50

# Detection Model Settings
MODEL_PATH=./data/instaguard_model.pth
MODEL_DEVICE=cpu
CONFIDENCE_THRESHOLD=0.5

# Application Settings
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
